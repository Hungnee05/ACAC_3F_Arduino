#include <Arduino.h>
enum StateA1 { a11, a12, a13, a14 };
enum StateA2 { a21, a22, a23, a24 };
enum StateB1 { b11, b12, b13, b14 };
enum StateB2 { b21, b22, b23, b24 };
enum StateC1 { c11, c12, c13, c14 };
enum StateC2 { c21, c22, c23, c24 };

StateA1 SA1 = a11; StateA2 SA2 = a21;
StateB1 SB1 = b11; StateB2 SB2 = b21;
StateC1 SC1 = c11; StateC2 SC2 = c21;

uint16_t tStartA1, tStartA2, tStartB1, tStartB2, tStartC1, tStartC2;
uint16_t alpha = 6667;
uint16_t kA1 = 0, kA2 = 0, kB1 = 0, kB2 = 0, kC1 = 0, kC2 = 0;
const uint16_t T = 100;
const uint16_t n = 1;
uint8_t lastA = 1, lastB = 1, lastC = 1;

#define T1_ON  PORTE |= (1<<PE4)
#define T1_OFF PORTE &= ~(1<<PE4)
#define T4_ON  PORTE |= (1<<PE3)
#define T4_OFF PORTE &= ~(1<<PE3)
#define T3_ON  PORTG |= (1<<PG5)
#define T3_OFF PORTG &= ~(1<<PG5)
#define T6_ON  PORTH |= (1<<PH4)
#define T6_OFF PORTH &= ~(1<<PH4)
#define T5_ON  PORTH |= (1<<PH3)
#define T5_OFF PORTH &= ~(1<<PH3)
#define T2_ON  PORTE |= (1<<PE5)
#define T2_OFF PORTE &= ~(1<<PE5)
#define READ_DIS (PINC & (1<<PC4))

volatile uint16_t offA1 = 0, offA2 = 0;
volatile uint16_t offB1 = 0, offB2 = 0;
volatile uint16_t offC1 = 0, offC2 = 0;

void setupTimer1()
{
  TCCR1A = 0;
  TCCR1B = 0;
  TCCR1B |= (1<<CS11);
}

ISR(TIMER1_COMPA_vect)
{
  uint16_t now = TCNT1;
  if(offA1 && (int16_t)(now - offA1) >= 0){ T1_OFF; offA1 = 0; }
  if(offA2 && (int16_t)(now - offA2) >= 0){ T4_OFF; offA2 = 0; }
  uint16_t next = 0xFFFF;
  if(offA1) next = offA1;
  if(offA2 && (int16_t)(offA2 - next) < 0) next = offA2;
  if(next != 0xFFFF) OCR1A = next;
  else TIMSK1 &= ~(1<<OCIE1A);
}

ISR(TIMER1_COMPB_vect)
{
  uint16_t now = TCNT1;
  if(offB1 && (int16_t)(now - offB1) >= 0){ T3_OFF; offB1 = 0; }
  if(offB2 && (int16_t)(now - offB2) >= 0){ T6_OFF; offB2 = 0; }
  uint16_t next = 0xFFFF;
  if(offB1) next = offB1;
  if(offB2 && (int16_t)(offB2 - next) < 0) next = offB2;
  if(next != 0xFFFF) OCR1B = next;
  else TIMSK1 &= ~(1<<OCIE1B);
}

ISR(TIMER1_COMPC_vect)
{
  uint16_t now = TCNT1;
  if(offC1 && (int16_t)(now - offC1) >= 0){ T5_OFF; offC1 = 0; }
  if(offC2 && (int16_t)(now - offC2) >= 0){ T2_OFF; offC2 = 0; }
  uint16_t next = 0xFFFF;
  if(offC1) next = offC1;
  if(offC2 && (int16_t)(offC2 - next) < 0) next = offC2;
  if(next != 0xFFFF) OCR1C = next;
  else TIMSK1 &= ~(1<<OCIE1C);
}

void setup()
{
  DDRD &= ~((1<<PD3)|(1<<PD2)|(1<<PD1));
  PORTD |= (1<<PD3)|(1<<PD2)|(1<<PD1);
  DDRE |= (1<<PE4)|(1<<PE3)|(1<<PE5);
  DDRG |= (1<<PG5);
  DDRH |= (1<<PH3)|(1<<PH4);
  DDRC &= ~(1<<PC4);
  PORTC |= (1<<PC4);
  setupTimer1();
}

